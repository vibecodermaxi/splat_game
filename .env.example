# ============================================================
# Pixel Predict — Environment Variables
# ============================================================
# Copy to the appropriate location:
#   Frontend: app/.env.local
#   Oracle:   oracle/.env
# ============================================================

# --- Shared (used by multiple subsystems) ---
# Solana RPC URL (Helius recommended for WebSocket support)
# Frontend uses NEXT_PUBLIC_ prefix for client-side access
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Program ID (deployed Anchor program)
# Frontend reads from constants.ts (hardcoded after deploy)
PROGRAM_ID=FaVo1qzkbVt1uPwyU4jRZ7hgkJbYTzat8iqtPE3orxQG

# Round timing — controls oracle cron and frontend countdown
# 30 for mainnet (30-min rounds), 5 for devnet (5-min rounds)
ROUND_DURATION_MINUTES=30
# Frontend reads this as NEXT_PUBLIC_ROUND_DURATION_SECONDS
NEXT_PUBLIC_ROUND_DURATION_SECONDS=1800

# --- Oracle only ---
ORACLE_KEYPAIR=[1,2,3,...,64]
ANTHROPIC_API_KEY=sk-ant-...
CURRENT_SEASON=1
TREASURY_WALLET=6vTe3xRjB4Hv4fN4WQ5xtcF21Ed12DFPoNwHJTZDUg5v
JACKPOT_WALLET=HrfnbCNRzvekRkdUJGzvmEu478F43uk7weReNDPqv2TB
SEASON_STYLE_SUMMARY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Frontend only ---
# Helius WebSocket URL for account change subscriptions
# (Connection object uses the RPC URL for WS automatically on devnet)
