  "types": [
    {
      "name": "BetAccount",
      "docs": [
        "Individual bet by a player on a specific pixel",
        "PDA seeds: [\"bet\", season_number.to_le_bytes(), pixel_index.to_le_bytes(), player.key()]",
        "",
        "One bet account per (player, pixel) pair — players must commit to a single color per pixel.",
        "Amount can be increased (via place_bet again) until betting locks."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "player",
            "docs": [
              "Player who placed this bet"
            ],
            "type": "pubkey"
          },
          {
            "name": "season_number",
            "docs": [
              "Season this bet belongs to"
            ],
            "type": "u16"
          },
          {
            "name": "pixel_index",
            "docs": [
              "Pixel this bet is for (0-99)"
            ],
            "type": "u16"
          },
          {
            "name": "color",
            "docs": [
              "Color this player bet on (0-15) — cannot be changed after initial bet"
            ],
            "type": "u8"
          },
          {
            "name": "amount",
            "docs": [
              "Total lamports bet by this player on this pixel (can increase up to MAX_BET_PER_COLOR)"
            ],
            "type": "u64"
          },
          {
            "name": "claimed",
            "docs": [
              "True if winnings have been claimed — prevents double-claiming"
            ],
            "type": "bool"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed"
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "ConfigAccount",
      "docs": [
        "Singleton configuration PDA",
        "PDA seeds: [\"config\"]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "admin",
            "docs": [
              "Admin authority — can rotate oracle key and manage seasons"
            ],
            "type": "pubkey"
          },
          {
            "name": "oracle",
            "docs": [
              "Oracle keypair pubkey — named `oracle` for Anchor `has_one` compatibility",
              "Admin can rotate this without program redeployment"
            ],
            "type": "pubkey"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed"
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "PixelState",
      "docs": [
        "Pixel round state — one entry per pixel per season",
        "PDA seeds: [\"pixel\", season_number.to_le_bytes(), pixel_index.to_le_bytes()]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "season_number",
            "docs": [
              "Season this pixel belongs to"
            ],
            "type": "u16"
          },
          {
            "name": "pixel_index",
            "docs": [
              "Sequential pixel index within the season (0-99)",
              "Maps to canvas position: x = pixel_index % grid_width, y = pixel_index / grid_width"
            ],
            "type": "u16"
          },
          {
            "name": "x",
            "docs": [
              "X coordinate on canvas (0-9)"
            ],
            "type": "u8"
          },
          {
            "name": "y",
            "docs": [
              "Y coordinate on canvas (0-9)"
            ],
            "type": "u8"
          },
          {
            "name": "status",
            "docs": [
              "Current round lifecycle status"
            ],
            "type": {
              "defined": {
                "name": "RoundStatus"
              }
            }
          },
          {
            "name": "color_pools",
            "docs": [
              "Lamports bet per color (indexed 0-15 matching the 16 game colors)"
            ],
            "type": {
              "array": [
                "u64",
                16
              ]
            }
          },
          {
            "name": "total_pool",
            "docs": [
              "Sum of all color_pools — total lamports in this round's pool"
            ],
            "type": "u64"
          },
          {
            "name": "winning_color",
            "docs": [
              "Winning color index (0-15), None until round is Resolved"
            ],
            "type": {
              "option": "u8"
            }
          },
          {
            "name": "shade",
            "docs": [
              "Visual shade modifier (0-100), None until round is Resolved"
            ],
            "type": {
              "option": "u8"
            }
          },
          {
            "name": "warmth",
            "docs": [
              "Visual warmth modifier (0-100), None until round is Resolved"
            ],
            "type": {
              "option": "u8"
            }
          },
          {
            "name": "prompt_hash",
            "docs": [
              "SHA-256 hash of the full AI prompt pre-committed at round open",
              "Enables commit-reveal verifiability"
            ],
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "arweave_txid",
            "docs": [
              "Arweave transaction ID where the full prompt text is stored (43 bytes, base58)",
              "All zeros means not yet uploaded — check has_arweave_txid flag"
            ],
            "type": {
              "array": [
                "u8",
                43
              ]
            }
          },
          {
            "name": "has_arweave_txid",
            "docs": [
              "True when arweave_txid has been set (since [u8; 43] cannot use Option<> with InitSpace)"
            ],
            "type": "bool"
          },
          {
            "name": "vrf_resolved",
            "docs": [
              "True if VRF fallback was used for resolution (AI was unavailable)"
            ],
            "type": "bool"
          },
          {
            "name": "opened_at",
            "docs": [
              "Unix timestamp when round was opened for betting"
            ],
            "type": "i64"
          },
          {
            "name": "locked_at",
            "docs": [
              "Unix timestamp when round was locked (28-min window elapsed), None until locked"
            ],
            "type": {
              "option": "i64"
            }
          },
          {
            "name": "resolved_at",
            "docs": [
              "Unix timestamp when round was resolved, None until resolved"
            ],
            "type": {
              "option": "i64"
            }
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed"
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "PlayerSeasonStats",
      "docs": [
        "Per-player per-season statistics",
        "PDA seeds: [\"stats\", season_number.to_le_bytes(), player.key()]",
